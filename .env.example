# === Sentry Error Tracking ===
# Get your DSN from https://sentry.io/settings/{org}/projects/{project}/keys/
VITE_SENTRY_DSN=

# === Stellar Network ===
# Supported values: https://soroban-testnet.stellar.org | https://soroban-mainnet.stellar.org | https://rpc-futurenet.stellar.org
VITE_RPC_URL=https://soroban-testnet.stellar.org
# See stellar-sdk Networks enum or Stellar docs
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# === Soroban Contract Addresses ===
# Deploy contracts via `soroban contract deploy` and paste the IDs here
VITE_RWA_FACTORY_CONTRACT=
VITE_INVESTOR_REGISTRY_CONTRACT=
VITE_DIVIDEND_DISTRIBUTOR_CONTRACT=
VITE_COMPLIANCE_MANAGER_CONTRACT=

# === Feature Flags ===
# Set to 'true' or 'false' to override defaults from src/lib/features/flags.ts
# VITE_FF_DividendDistribution=true
# VITE_FF_InvestorWhitelisting=true
# VITE_FF_TransferRestrictions=true
# VITE_FF_DarkMode=true
# VITE_FF_ContractDeploy=true
# VITE_FF_KycProviderCustom=false
